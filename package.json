{
  "name": "budget-me",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration=local",
    "build": "ng build",
    "docker-dev-build": "docker compose -p dev --env-file .env.dev -f docker-compose.dev.yaml up --build ",
    "docker-dev-start": "docker compose -p dev --env-file .env.dev -f docker-compose.dev.yaml start ",
    "docker-dev-stop": "docker compose -p dev --env-file .env.dev -f docker-compose.dev.yaml stop",
    "docker-dev-remove": "docker compose -p dev --env-file .env.dev -f docker-compose.dev.yaml down -v",
    "docker-prod-build": "docker compose -p prod --env-file .env.prod -f docker-compose.prod.yaml up --build ",
    "docker-prod-start": "docker compose -p prod --env-file .env.prod -f docker-compose.prod.yaml up",
    "docker-prod-stop": "docker compose -p prod --env-file .env.prod -f docker-compose.prod.yaml down",
    "docker-prod-remove": "docker compose -p prod --env-file .env.prod -f docker-compose.prod.yaml down -v",
    "docker-shell-frontend": "docker exec -it prod-frontend-1 sh",
    "docker-shell-backend": "docker exec -it prod-backend-1 sh",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.15",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.15",
    "@angular/compiler": "^19.2.15",
    "@angular/core": "^19.2.15",
    "@angular/forms": "^19.2.15",
    "@angular/material": "^19.2.19",
    "@angular/material-moment-adapter": "^19.2.19",
    "@angular/platform-browser": "^19.2.15",
    "@angular/platform-browser-dynamic": "^19.2.15",
    "@angular/router": "^19.2.15",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.17",
    "@angular/cli": "^19.2.17",
    "@angular/compiler-cli": "^19.2.15",
    "@types/jasmine": "~4.3.0",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.8.3"
  }
}
